# Copy this file to .env, then fill in your real DeepSeek key.
# Never put DEEPSEEK_API_KEY in frontend files such as index.html or app.js.

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
PORT=4174

# Optional tuning
AI_TIMEOUT_MS=120000
DEEPSEEK_MAX_TOKENS=1800
MAX_RESUME_TEXT_CHARS=12000
MAX_BODY_BYTES=12000000
